{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "noEmit": true,
    "strict": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "paths": {
      "@helmr/proto": ["../../proto/typescript/src/index.ts"],
      "@helmr/sdk": ["../../sdk/typescript/src/index.ts"],
      "@helmr/sdk/*": ["../../sdk/typescript/src/*"]
    }
  },
  "include": ["tasks/**/*.ts", "helmr.config.ts"]
}

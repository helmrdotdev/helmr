# Copy to a local .tfvars file and fill the required values when using the
# dev stack as an ephemeral full-run smoke environment.

aws_region  = "us-east-1"
name        = "helmr-smoke"
public_url  = "https://helmr-smoke.example.com"

enable_nat_gateway = true

control_image        = "<account>.dkr.ecr.us-east-1.amazonaws.com/helmr-smoke/control:<digest>"
certificate_arn      = null
enable_cloudfront    = true
github_app_id        = "123456"
github_app_slug      = "helmr-dev"
github_app_client_id = "Iv1..."
setup_enabled = true
bootstrap_owner_email = "admin@example.com"

control_assign_public_ip = false

database_deletion_protection    = false
database_backup_retention_days  = 1
database_skip_final_snapshot    = true
control_repository_force_delete = true

create_control_service = true
control_desired_count  = 1

# Worker hosts require an AMI with Firecracker, jailer, BuildKit, CNI plugins,
# guest boot artifacts, AWS CLI, and helmr-worker already installed.
create_worker                       = true
worker_ami_id                       = "ami-..."
worker_instance_type                = "c8i.xlarge"
worker_enable_nested_virtualization = true
worker_desired_capacity             = 1
worker_min_size                     = 1
worker_max_size                     = 1

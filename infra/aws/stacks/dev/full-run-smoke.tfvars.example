# Copy to a local .tfvars file and fill the required values when using the
# dev stack as an ephemeral full-run smoke environment.

aws_region  = "us-east-1"
name        = "helmr-smoke"
public_url  = "https://helmr-smoke.example.com"

worker_group_id   = "us-east-1-worker-group-1"
region_id         = "us-east-1"
default_region_id = "us-east-1"

enable_nat_gateway = true

control_image        = "<account>.dkr.ecr.us-east-1.amazonaws.com/helmr-smoke/control@sha256:<digest>"
certificate_arn      = "arn:aws:acm:us-east-1:123456789012:certificate/replace-me"
allow_insecure_http  = false
enable_cloudfront    = true
cloudfront_origin_domain_name = "origin.helmr-smoke.example.com"
github_oauth_client_id = "Iv1..."

create_clickhouse_cloud  = true
clickhouse_organization_id = "<clickhouse-cloud-organization-id>"
# Optional managed ClickHouse tuning:
# clickhouse_cloud_service_name = "helmr-smoke-telemetry"
# clickhouse_cloud_region       = "us-east-1"
# clickhouse_secret_kms_key_id  = "arn:aws:kms:us-east-1:123456789012:key/replace-me"

# To bring an existing ClickHouse service instead, set create_clickhouse_cloud=false
# and provide its endpoint plus a Secrets Manager password secret ARN:
# clickhouse_url                 = "https://replace-me.clickhouse.cloud:8443"
# clickhouse_user                = "default"
# clickhouse_password_secret_arn = "arn:aws:secretsmanager:us-east-1:123456789012:secret:replace-me"
# clickhouse_password_kms_key_arns = ["<clickhouse-password-kms-key-arn>"]
# additional_control_security_group_ids = ["<clickhouse-client-security-group-id>"]

control_assign_public_ip = false

database_deletion_protection    = false
database_backup_retention_days  = 1
database_skip_final_snapshot    = true
control_repository_force_delete = true
secret_recovery_window_in_days  = 0

create_control_service = true
control_desired_count    = 1
dispatcher_desired_count = 1

# Email delivery is disabled by default. For Resend, uncomment these values,
# apply, then populate the emitted secret_arns.resend_api_key secret.
# email_provider = "resend"
# email_from     = "Helmr <noreply@example.com>"

redis_node_type  = "cache.t4g.micro"
redis_node_count = 1

# Worker instances require an AMI with Firecracker, jailer, BuildKit, CNI plugins,
# guest boot artifacts, AWS CLI, and helmr-worker already installed.
create_worker                       = true
worker_ami_id                       = "ami-..."
worker_allowed_ami_ids              = []
worker_instance_type                = "c8i.xlarge"
worker_enable_nested_virtualization = true
worker_min_size                     = 0
worker_max_size                     = 1
build_worker_min_size               = 0
build_worker_max_size               = 1
worker_root_volume_size_gb          = 120
worker_root_volume_iops             = 3000
worker_root_volume_throughput       = 125
worker_disk_mib                     = 98304
worker_vm_vcpus                     = 2
worker_vm_memory_mib                = 4096
worker_vm_scratch_disk_mib          = 32768
worker_capacity_vcpus               = 4
worker_capacity_memory_mib          = 8192
worker_execution_slots              = 1

# Queued build/run demand scales each application-owned ASG to one.
worker_fleet_controller = {
  run_warm_workers             = 0
  build_warm_workers           = 0
  run_max_workers              = 1
  build_max_workers            = 1
  max_scale_out_per_cycle      = 1
  max_pending_workers          = 1
  max_packing_items            = 10000
  controller_interval_seconds  = 15
  scale_out_cooldown_seconds   = 30
  scale_in_cooldown_seconds    = 300
  scale_in_hysteresis_seconds  = 300
  stale_worker_timeout_seconds = 120
  readiness_timeout_seconds    = 900
  drain_timeout_seconds        = 1800
  emergency_stop               = false
  metric_interval_seconds      = 60
}

aws_region = "us-east-1"
name       = "helmr-standard"
public_url = "https://helmr.example.com"

helmr_version = "replace-with-helmr-release-version"

certificate_arn = "<acm-certificate-arn>"

github_oauth_client_id = "<github-oauth-client-id>"

clickhouse_url  = "https://replace-me.clickhouse.cloud:8443"
clickhouse_user = "default"
clickhouse_password_secret_arn = "arn:aws:secretsmanager:us-east-1:123456789012:secret:replace-me"
# When the ClickHouse password secret uses a customer-managed key outside this
# stack, allow the control and dispatcher execution roles to decrypt it.
# clickhouse_password_kms_key_arns = ["<clickhouse-password-kms-key-arn>"]
# When using the ClickHouse Cloud PrivateLink module, attach its client security
# group to control, dispatcher, and migration tasks.
# additional_control_security_group_ids = ["<clickhouse-client-security-group-id>"]

# Keep create_control_service=false for the first apply. Populate the emitted
# Secrets Manager secrets, run migrations, then set it true.
create_control_service = false
control_desired_count    = 2
dispatcher_desired_count = 1

# Email delivery is disabled by default. For Resend, uncomment these values,
# apply, then populate the emitted secret_arns.resend_api_key secret.
# email_provider = "resend"
# email_from     = "Helmr <noreply@example.com>"

enable_cloudfront = false

# Dispatch queue. The standard baseline uses two nodes for automatic failover.
redis_node_type  = "cache.t4g.small"
redis_node_count = 2

database_multi_az              = true
database_deletion_protection   = true
database_backup_retention_days = 14
database_skip_final_snapshot   = false

# Optional custom builds. Leave null to use the official release artifacts.
control_image = null
worker_ami_id = null

create_worker           = false
worker_desired_capacity = 0
worker_min_size         = 0
worker_root_volume_size_gb    = 500
worker_root_volume_iops       = 12000
worker_root_volume_throughput = 500
worker_disk_mib               = null
worker_vm_vcpus               = 2
worker_vm_memory_mib          = 4096
worker_vm_scratch_disk_mib    = 32768

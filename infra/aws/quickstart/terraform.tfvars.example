aws_region = "us-east-1"
name       = "helmr-quickstart"

helmr_version = "replace-with-helmr-release-version"

# Direct ALB quickstart. To enable CloudFront, also set
# cloudfront_origin_domain_name to a DNS name that resolves to the public ALB.
enable_cloudfront = false
public_url        = "https://helmr.example.com"
certificate_arn   = "arn:aws:acm:us-east-1:123456789012:certificate/replace-me"

enable_nat_gateway       = false
control_assign_public_ip = true

github_oauth_client_id = "replace-with-github-oauth-client-id"

create_control_service = false
control_desired_count    = 1
dispatcher_desired_count = 1

# Email delivery is disabled by default. For Resend, uncomment these values,
# apply, then populate the emitted secret_arns.resend_api_key secret.
# email_provider = "resend"
# email_from     = "Helmr <noreply@example.com>"

# Dispatch queue. Quickstart uses a single node for lower cost.
redis_node_type  = "cache.t4g.micro"
redis_node_count = 1

# Optional custom builds. Leave null to use the official release artifacts.
control_image = null
worker_ami_id = null

# Optional smoke worker. The official worker AMI is resolved from helmr_version
# and aws_region. NAT Gateway is required because workers run in private subnets.
create_worker                       = false
worker_instance_type                = "c8i.xlarge"
worker_enable_nested_virtualization = true
worker_desired_capacity             = 1
worker_min_size                     = 1
worker_max_size                     = 1
worker_root_volume_size_gb          = 120
worker_root_volume_iops             = 3000
worker_root_volume_throughput       = 125
worker_disk_mib                     = null
worker_vm_vcpus                     = 2
worker_vm_memory_mib                = 4096
worker_vm_scratch_disk_mib          = 32768

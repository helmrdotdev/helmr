{
  "name": "helmr",
  "private": true,
  "license": "Apache-2.0",
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "sdk/typescript",
    "proto/typescript",
    "runtime/typescript",
    "examples/dependency-cache",
    "examples/cli-tooling",
    "examples/github-pr-review",
    "examples/hello-world",
    "examples/human-in-the-loop",
    "examples/resend-email-approval",
    "examples/slack-approval",
    "examples/task-secrets",
    "packages/*"
  ],
  "overrides": {
    "@babel/core": "7.29.7",
    "esbuild": "0.28.1",
    "js-yaml": "4.2.0",
    "undici": "7.28.0",
    "yaml": "2.9.0",
    "ws": "8.21.0"
  },
  "devDependencies": {
    "@tsconfig/bun": "^1.0.10",
    "@types/node": "^24.13.2",
    "bun-types": "^1.3.14",
    "typescript": "^5.9.3",
    "wrangler": "4.102.0"
  },
  "scripts": {
    "buf": "buf",
    "projects:typecheck": "scripts/ts-projects-typecheck.sh",
    "gen:proto": "bun run --cwd proto/typescript gen",
    "test:ts": "bun test sdk/typescript/src runtime/typescript/src",
    "typecheck": "bun run --cwd proto/typescript typecheck && bun run --cwd sdk/typescript typecheck && bun run --cwd runtime/typescript typecheck && bun run --cwd packages/console typecheck && bun run --cwd packages/web typecheck && bun run projects:typecheck",
    "build:npm": "scripts/build-npm-packages.sh",
    "pack:npm": "scripts/pack-npm-packages.sh",
    "dev:web": "bun run --cwd packages/web dev",
    "build:web": "bun run --cwd packages/web build",
    "deploy:web": "bun run build:web && wrangler deploy --config wrangler.jsonc",
    "typecheck:web": "bun run --cwd packages/web typecheck"
  }
}

---
import DocsLayout from "../../layouts/DocsLayout.astro";
import { getDocs } from "../../lib/docs";
import { pixelsFromRows } from "../../lib/pixels";

const docs = await getDocs();

const entryIcons = {
  bolt: [
    "..........",
    ".....##...",
    "....##....",
    "...##.....",
    "..######..",
    "....##....",
    "...##.....",
    "..##......",
    ".##.......",
    "..........",
  ],
  layers: [
    "....##....",
    "..######..",
    "##########",
    "..######..",
    "....##....",
    "..........",
    "##......##",
    "..##..##..",
    "....##....",
    "..........",
  ],
  cloud: [
    "..........",
    "..........",
    "..##..##..",
    ".########.",
    "##########",
    "##########",
    ".########.",
    "..........",
    "..........",
    "..........",
  ],
  terminal: [
    "..........",
    "##########",
    "#........#",
    "#.#......#",
    "#..#.....#",
    "#.#......#",
    "#....###.#",
    "#........#",
    "##########",
    "..........",
  ],
} as const;

const entryPoints = [
  {
    section: "Start",
    title: "Start with Helmr",
    description: "Install the CLI, connect to a control plane, and run a small task in a durable workspace.",
    href: "/docs/start/overview",
    icon: pixelsFromRows(entryIcons.bolt),
    tone: "yellow",
    links: [
      { label: "Quickstart", href: "/docs/start/quickstart" },
      { label: "First task", href: "/docs/guides/first-task" },
    ],
  },
  {
    section: "Concepts",
    title: "Understand the runtime",
    description: "See how task projects, sandboxes, workspaces, sessions, runs, streams, tokens, timers, and secrets fit together.",
    href: "/docs/concepts/product-model",
    icon: pixelsFromRows(entryIcons.layers),
    tone: "blue",
    links: [
      { label: "Workspaces", href: "/docs/concepts/workspaces" },
      { label: "Sessions", href: "/docs/concepts/sessions" },
      { label: "Runs", href: "/docs/concepts/runs" },
    ],
  },
  {
    section: "Self-hosting",
    title: "Self-host in AWS",
    description: "Create the control plane, configure OAuth and Secrets Manager, then add Firecracker workers.",
    href: "/docs/self-hosting/overview",
    icon: pixelsFromRows(entryIcons.cloud),
    tone: "green",
    links: [
      { label: "Deploy on AWS", href: "/docs/self-hosting/deploy-on-aws" },
      { label: "Verify a run", href: "/docs/self-hosting/verify-run" },
    ],
  },
  {
    section: "Reference",
    title: "Check commands and APIs",
    description: "Look up CLI commands, SDK authoring, runtime APIs, run events, and environment variables.",
    href: "/docs/reference/cli",
    icon: pixelsFromRows(entryIcons.terminal),
    tone: "pink",
    links: [
      { label: "REST API", href: "/docs/reference/rest-api" },
      { label: "Environment variables", href: "/docs/reference/environment-variables" },
    ],
  },
];
---

<DocsLayout title="Helmr Docs" description="Documentation for installing, operating, and extending Helmr." docs={docs}>
  <h1>Docs</h1>
  <p>
    Set up Helmr, define TypeScript tasks, attach them to durable workspaces, and operate the self-hosted runtime in your AWS account.
  </p>
  <div class="docs-index-grid">
    {entryPoints.map((entry) => (
      <section>
        <a class="entry-main" href={entry.href} data-astro-prefetch="viewport">
          <span class="entry-head">
            <svg class="entry-icon" viewBox="0 0 10 10" aria-hidden="true" style={`background: var(--wash-${entry.tone})`}>
              {entry.icon.map((pixel) => (
                <rect x={pixel.x} y={pixel.y} width="1" height="1" />
              ))}
            </svg>
            <span class="entry-section">{entry.section}</span>
          </span>
          <strong>{entry.title}</strong>
          <p>{entry.description}</p>
        </a>
        <div class="entry-links" aria-label={`${entry.section} links`}>
          {entry.links.map((link) => (
            <a href={link.href} data-astro-prefetch="viewport">{link.label}</a>
          ))}
        </div>
      </section>
    ))}
  </div>
</DocsLayout>

<style>
  .docs-index-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0;
    margin-top: 1.4rem;
    border-top: 1px solid var(--border);
    border-left: 1px solid var(--border);
  }

  .docs-index-grid section {
    border-right: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    background: var(--surface-raised);
  }

  .entry-main {
    display: block;
    min-height: 8rem;
    color: var(--text);
    padding: 0.85rem;
    text-decoration: none;
    transition: background 0.1s ease-out, color 0.1s ease-out;
  }

  .entry-main:hover {
    background: var(--surface-dim);
  }

  .entry-main:hover strong {
    color: var(--accent);
  }

  .entry-head {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    margin-bottom: 0.65rem;
  }

  .entry-icon {
    width: 26px;
    height: 26px;
    flex: 0 0 auto;
    padding: 5px;
    fill: var(--ink);
    shape-rendering: crispEdges;
  }

  .entry-section {
    color: var(--text-subtle);
    font-family: var(--font-mono);
    font-size: 0.62rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .entry-main strong {
    display: block;
    font-family: var(--font-sans);
    font-size: 0.9rem;
    font-weight: 500;
    line-height: 1.2;
  }

  .entry-main p {
    margin-top: 0.55rem;
    color: var(--text-muted);
    font-size: 0.76rem;
    line-height: 1.55;
  }

  .entry-links {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    border-top: 1px solid var(--border);
  }

  .entry-links a {
    min-height: 2.45rem;
    color: var(--text-muted);
    padding: 0.7rem 0.85rem;
    font-size: 0.74rem;
    line-height: 1.2;
    text-decoration: none;
  }

  .entry-links a + a {
    border-left: 1px solid var(--border);
  }

  .entry-links a:hover {
    background: var(--accent-wash);
    color: var(--accent);
  }

  @media (max-width: 640px) {
    .docs-index-grid {
      grid-template-columns: 1fr;
    }

    .entry-links {
      grid-template-columns: 1fr;
    }

    .entry-links a + a {
      border-top: 1px solid var(--border);
      border-left: 0;
    }
  }
</style>

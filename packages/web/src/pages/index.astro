---
import BaseLayout from "../layouts/BaseLayout.astro";
import { pixelsFromRows } from "../lib/pixels";
import { breadcrumbJsonLd, softwareJsonLd } from "../lib/seo";

const runtimeCode = `import { cache, image, sandbox, source, task } from "@helmr/sdk"
import { Codex } from "@openai/codex-sdk"

const base = image("repo-agent")
  .from("node:24-bookworm-slim")
  .workdir("/workspace")
  .run(["sh", "-ceu", "apt-get update && apt-get install -y git ripgrep"])
  .copy("/workspace/package.json", source.file("package.json"))
  .run(["bun", "install"], {
    cache: [{ mountPath: "/root/.bun/install/cache", cache: cache("bun") }]
  })

const sbx = sandbox("repo-agent")
  .image(base)
  .resources({ cpu: 2, memory: "4Gi" })

export const reviewPr = task({
  id: "review-pr",
  sandbox: sbx,
  queue: { concurrencyLimit: 5 },
  secrets: [{ name: "OPENAI_API_KEY", env: "OPENAI_API_KEY" }],
  run: async (event, ctx) => {
    const codex = new Codex()
    const thread = codex.startThread({ workingDirectory: process.cwd() })
    const turn = await thread.run("Review this PR and propose a patch.")

    // The microVM freezes here — filesystem, memory, process.
    const decision = await ctx.wait.human<{ approved: boolean }>({
      displayText: "Post this review to GitHub?"
    })
    if (decision.approved) await postReview(event.prNumber, turn.finalResponse)
  }
})`;

const escapeHtml = (value: string) =>
  value
    .replaceAll("&", "&amp;")
    .replaceAll("<", "&lt;")
    .replaceAll(">", "&gt;");

const syntaxKeywords = ["import", "from", "export", "const", "new", "async", "await", "if", "as"] as const;
const syntaxLiterals = ["true", "false", "null", "undefined"] as const;
const syntaxReserved = new Set<string>([...syntaxKeywords, ...syntaxLiterals]);
const syntaxReservedPattern = [...syntaxKeywords, ...syntaxLiterals].join("|");

const highlightTypeScript = (value: string) => {
  const tokenPattern = new RegExp(
    `("(?:\\\\.|[^"\\\\])*"|'(?:\\\\.|[^'\\\\])*'|\\/\\/.*|\\b(?:${syntaxReservedPattern})\\b|\\b\\d+\\b|\\.[A-Za-z_$][\\w$]*|\\b[A-Za-z_$][\\w$]*(?=\\()|[{}()[\\].,:])`,
    "g",
  );
  let cursor = 0;
  let html = "";

  for (const match of value.matchAll(tokenPattern)) {
    const token = match[0];
    const index = match.index ?? 0;
    html += escapeHtml(value.slice(cursor, index));

    let tokenClass = "tok-punct";
    if (token.startsWith('"') || token.startsWith("'")) tokenClass = "tok-string";
    else if (token.startsWith("//")) tokenClass = "tok-comment";
    else if (/^\d+$/.test(token)) tokenClass = "tok-number";
    else if (token.startsWith(".")) tokenClass = "tok-property";
    else if (syntaxReserved.has(token)) {
      tokenClass = "tok-keyword";
    } else if (/^[A-Za-z_$]/.test(token)) {
      tokenClass = "tok-call";
    }

    html += `<span class="${tokenClass}">${escapeHtml(token)}</span>`;
    cursor = index + token.length;
  }

  return html + escapeHtml(value.slice(cursor));
};

const codeLines = runtimeCode.split("\n").map((line) => ({
  html: highlightTypeScript(line) || "&nbsp;",
  marked: line.includes("microVM freezes"),
}));

const highlightShell = (value: string) =>
  value
    .split("\n")
    .map((line) =>
      line.startsWith("$ ")
        ? `<span class="tok-prompt">$</span> ${escapeHtml(line.slice(2))}`
        : `<span class="tok-comment">${escapeHtml(line)}</span>`,
    )
    .join("\n");

const pixelIcons = {
  pause: [
    "..........",
    "..##..##..",
    "..##..##..",
    "..##..##..",
    "..##..##..",
    "..##..##..",
    "..##..##..",
    "..##..##..",
    "..##..##..",
    "..........",
  ],
  clock: [
    "...####...",
    "..#....#..",
    ".#..#...#.",
    "#...#....#",
    "#...#....#",
    "#...###..#",
    ".#......#.",
    "..#....#..",
    "...####...",
    "..........",
  ],
  bolt: [
    "..........",
    ".....##...",
    "....##....",
    "...##.....",
    "..######..",
    "....##....",
    "...##.....",
    "..##......",
    ".##.......",
    "..........",
  ],
  replay: [
    "...####...",
    "..#...###.",
    ".#....###.",
    "#......#..",
    "#.........",
    "#........#",
    ".#......#.",
    "..#....#..",
    "...####...",
    "..........",
  ],
} as const;

const features = [
  {
    label: "ctx.wait.human",
    icon: "pause",
    title: "Pause for a human",
    caption:
      "The microVM freezes whole and costs nothing while it waits. Approval resumes it mid-instruction.",
    code: `const decision = await ctx.wait.human<{ approved: boolean }>({
  displayText: "Post this review to GitHub?"
})`,
    lang: "ts",
  },
  {
    label: "schedules.task",
    icon: "clock",
    title: "Run on a schedule",
    caption: "Cron lives in the task definition and deploys with it. One file owns the code and the schedule.",
    code: `export const nightly = schedules.task({
  id: "nightly-audit",
  cron: { pattern: "0 9 * * 1-5", timezone: "Asia/Tokyo" },
  run: async (event, ctx) => runAudit(ctx)
})`,
    lang: "ts",
  },
  {
    label: "task.trigger",
    icon: "bolt",
    title: "Trigger from anywhere",
    caption: "Your product, a webhook, CI, or another task — deduplicated with idempotency keys.",
    code: `const handle = await reviewPr.trigger(
  { prNumber: 482 },
  { idempotencyKey: pr.head.sha }
)`,
    lang: "ts",
  },
  {
    label: "helmr replay",
    icon: "replay",
    title: "Replay any run",
    caption: "Re-run against the original deployment or the latest. Logs and events stream live.",
    code: `$ helmr replay run_8f3a --version latest
$ helmr logs run_8f3a --follow`,
    lang: "sh",
  },
] as const;

const renderedFeatures = features.map((feature) => ({
  ...feature,
  html: feature.lang === "ts" ? highlightTypeScript(feature.code) : highlightShell(feature.code),
  pixels: pixelsFromRows(pixelIcons[feature.icon]),
}));
---

<BaseLayout
  title="Helmr — The durable runtime for AI agents"
  socialTitle="The durable runtime for AI agents"
  description="The durable runtime for AI agents. Each run is a Firecracker microVM checkpointed whole at approval points — pause, resume, schedule, replay in plain TypeScript. On our cloud or in your AWS."
  path="/"
  jsonLd={[softwareJsonLd(), breadcrumbJsonLd([{ name: "Home", path: "/" }])]}
>
  <div class="landing">
    <section class="hero">
      <div class="hero-inner">
        <div class="hero-copy">
          <h1 class="headline hero-title">
            The durable runtime <span class="faint">for AI agents.</span>
          </h1>
          <p class="hero-lede">
            Define tasks in plain TypeScript. Each run gets its own microVM,
            checkpointed whole at approval points &mdash; pause, resume, replay.
          </p>
          <div class="hero-actions">
            <a class="btn btn-dark" href="/docs/start/quickstart">Start building</a>
            <a class="btn btn-light" href="https://github.com/helmrdotdev/helmr" target="_blank" rel="noopener">View on GitHub</a>
          </div>
          <button class="install-command" type="button" data-copy-install aria-label="Copy install command">
            <code data-install-command>curl -fsSL https://helmr.dev/install | bash</code>
            <span class="copy-control" aria-hidden="true">
              <svg class="copy-icon" viewBox="0 0 24 24" fill="none">
                <path d="M8.75 8.75V2.75H21.25V15.25H15.25M15.25 8.75H2.75V21.25H15.25V8.75Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="square" />
              </svg>
              <svg class="check-icon" viewBox="0 0 24 24" fill="none">
                <path d="M2.75 15.0938L9 20.25L21.25 3.75" stroke="currentColor" stroke-width="2" stroke-linecap="square" />
              </svg>
            </span>
          </button>
        </div>

        <div class="term panel">
          <div class="code-cap">
            <span>helmr — deploy → run</span>
            <span class="cap-meta">bash</span>
          </div>
          <div class="term-body" data-term>
            <p class="t-line"><span class="t-prompt">$</span> <span class="t-cmd">helmr deploy</span></p>
            <p class="t-line t-dim">Deployment dpl_4e21 queued</p>
            <p class="t-line"><span class="t-ok">v12</span></p>
            <p class="t-line t-gap"><span class="t-prompt">$</span> <span class="t-cmd">helmr run review-pr --payload prNumber=482</span></p>
            <p class="t-line">run_8f3a</p>
            <p class="t-line t-gap"><span class="t-prompt">$</span> <span class="t-cmd">helmr ps</span></p>
            <p class="t-line t-dim">RUN ID    TASK       STATUS   WAIT</p>
            <p class="t-line">run_8f3a  review-pr  <span class="t-wait">waiting</span>  <span class="t-accent">human:wp_c91d</span></p>
            <p class="t-line t-gap" data-cursor><span class="t-prompt">$</span> <span class="t-cursor"></span></p>
          </div>
          <div class="term-foot" data-term-foot>
            <span class="term-foot-note">run_8f3a waiting on wp_c91d</span>
            <button
              class="term-approve"
              type="button"
              data-approve
              aria-label="Approve the waitpoint and resume the run"
            >approve &amp; resume</button>
          </div>
        </div>
      </div>
      <div class="pixel-seam"></div>
    </section>

    <section id="runtime" class="code-section" aria-label="Runtime definition">
      <div class="section-head">
        <h2 class="headline section-title">
          One TypeScript file.
          <span class="faint">Image, sandbox, task, secrets, approval gate.</span>
        </h2>
        <p class="section-note">
          Codex here &mdash; or Claude Code, the AI SDK, any agent SDK that runs
          on Node. The boundary stays the same.
        </p>
      </div>
      <div class="code-frame panel">
        <div class="code-cap">
          <span>review-pr.ts</span>
          <span class="cap-meta">typescript</span>
        </div>
        <pre><code>{codeLines.map((line, i) => (
          <span class={line.marked ? "cl cl-mark" : "cl"}><span class="ln">{String(i + 1).padStart(2, " ")}</span><span class="lc" set:html={line.html}></span></span>
        ))}</code></pre>
      </div>
    </section>

    <section class="features" aria-label="What it looks like in code">
      <div class="section-head">
        <h2 class="headline section-title">
          Pause. Schedule. Trigger. Replay.
          <span class="faint">Each one is a few lines.</span>
        </h2>
      </div>
      <div class="feature-grid">
        {renderedFeatures.map((feature) => (
          <div class="feature">
            <div class="feature-head">
              <svg class="feature-icon" viewBox="0 0 10 10" aria-hidden="true">
                {feature.pixels.map((pixel) => (
                  <rect x={pixel.x} y={pixel.y} width="1" height="1" />
                ))}
              </svg>
              <h3 class="feature-title">{feature.title}</h3>
            </div>
            <div class="feature-panel panel">
              <div class="code-cap">
                <span>{feature.label}</span>
                <span class="cap-meta">{feature.lang === "ts" ? "typescript" : "bash"}</span>
              </div>
              <pre><code set:html={feature.html}></code></pre>
            </div>
            <p class="feature-caption">{feature.caption}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="homes" aria-label="Deployment options">
      <div class="section-head">
        <h2 class="headline section-title">
          Run on our cloud,
          <span class="faint">or in your AWS.</span>
        </h2>
        <p class="section-note mono">
          Early, open, Apache 2.0. Read the source before you trust it with your repos.
        </p>
      </div>
      <div class="homes-grid">
        <div class="home-card panel">
          <p class="home-label">Helmr Cloud <span class="chip chip-warm">coming soon</span></p>
          <p class="home-text">
            A managed fleet. Projects, environments, immutable deployments &mdash;
            no infrastructure to run.
          </p>
          <a class="btn btn-light" href="/docs">Read the docs</a>
        </div>
        <div class="home-card panel">
          <p class="home-label">Your AWS account</p>
          <p class="home-text">
            The identical control plane and workers in your VPC, Apache 2.0.
            Credentials never leave your boundary.
          </p>
          <a class="btn btn-dark" href="/docs/self-hosting/overview">Self-hosting guide</a>
        </div>
      </div>
    </section>

    <div class="circuit" aria-hidden="true">
      <i class="circuit-edge circuit-edge-out"></i>
      <i class="circuit-edge circuit-edge-rail"></i>
      <i class="circuit-edge circuit-edge-in"></i>
      <i class="circuit-node circuit-node-a"></i>
      <i class="circuit-node circuit-node-b"></i>
    </div>
  </div>

  <script>
    const copyInstallButton = document.querySelector("[data-copy-install]");
    const installCommand = document.querySelector("[data-install-command]");

    copyInstallButton?.addEventListener("click", async () => {
      const text = installCommand?.textContent?.trim();
      if (!text) return;
      try {
        await navigator.clipboard.writeText(text);
      } catch {
        return;
      }
      copyInstallButton.setAttribute("data-copied", "true");
      window.setTimeout(() => {
        copyInstallButton.removeAttribute("data-copied");
      }, 1600);
    });

    const landing = document.querySelector<HTMLElement>(".landing");
    const term = document.querySelector<HTMLElement>("[data-term]");
    const termFoot = document.querySelector<HTMLElement>("[data-term-foot]");
    const approveButton = document.querySelector<HTMLButtonElement>("[data-approve]");
    const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    const sleep = (ms: number) => new Promise<void>((resolve) => window.setTimeout(resolve, ms));

    const followScroll = () => {
      if (term) term.scrollTop = term.scrollHeight;
    };

    const typeInto = async (target: Element, text: string) => {
      for (const char of text) {
        target.textContent = (target.textContent ?? "") + char;
        followScroll();
        if (!reduceMotion) await sleep(24);
      }
    };

    const appendLine = (html: string, className: string) => {
      if (!term) return null;
      const line = document.createElement("p");
      line.className = className;
      line.innerHTML = html;
      term.appendChild(line);
      followScroll();
      return line;
    };

    const replayBoot = async () => {
      if (!term) return;
      const lines = Array.from(term.querySelectorAll<HTMLElement>(".t-line"));
      term.style.minHeight = `${term.offsetHeight}px`;
      for (const line of lines) line.hidden = true;
      await sleep(450);
      for (const line of lines) {
        if (line.dataset.cursor !== undefined) continue;
        const command = line.querySelector<HTMLElement>(".t-cmd");
        if (command) {
          const text = command.textContent ?? "";
          command.textContent = "";
          line.hidden = false;
          await sleep(300);
          await typeInto(command, text);
          if (text.startsWith("helmr run")) {
            runStarted = true;
            void maybeSweep();
          }
          await sleep(240);
        } else {
          line.hidden = false;
          await sleep(140);
        }
      }
      const cursorLine = term.querySelector<HTMLElement>("[data-cursor]");
      if (cursorLine) cursorLine.hidden = false;
    };

    const codeRows = Array.from(document.querySelectorAll<HTMLElement>(".code-frame .cl"));
    const markIndex = codeRows.findIndex((row) => row.classList.contains("cl-mark"));
    const waitIndex = markIndex >= 0 ? Math.min(markIndex + 1, codeRows.length - 1) : -1;
    let waitpointResolved = false;
    let runStarted = false;
    let executedUntil = -1;
    let sweepBusy = false;

    const sweepTo = async (target: number) => {
      sweepBusy = true;
      for (let i = executedUntil + 1; i <= target; i++) {
        const row = codeRows[i];
        row.classList.add("cl-active");
        if (!reduceMotion) await sleep(36);
        if (!(i === waitIndex && !waitpointResolved)) row.classList.remove("cl-active");
        row.classList.add("cl-done");
        executedUntil = i;
      }
      sweepBusy = false;
    };

    const maybeSweep = async () => {
      if (!runStarted || waitIndex < 0 || sweepBusy) return;
      const target = waitpointResolved ? codeRows.length - 1 : waitIndex;
      if (waitpointResolved) codeRows[waitIndex]?.classList.remove("cl-active");
      if (target > executedUntil) {
        await sweepTo(target);
        void maybeSweep();
      }
    };

    approveButton?.addEventListener("click", async () => {
      if (!term || waitpointResolved) return;
      waitpointResolved = true;
      landing?.setAttribute("data-wp-resolved", "");
      term.setAttribute("data-resolved", "");
      termFoot?.removeAttribute("data-ready");
      // Pin the height so the page doesn't shift; old lines scroll out like a real terminal.
      term.style.height = `${term.offsetHeight}px`;
      term.style.minHeight = "";
      term.style.overflowY = "hidden";

      const cursorLine = term.querySelector<HTMLElement>("[data-cursor]");
      cursorLine?.querySelector(".t-cursor")?.remove();
      cursorLine?.removeAttribute("data-cursor");
      const respondCommand = document.createElement("span");
      cursorLine?.appendChild(respondCommand);
      await typeInto(respondCommand, "helmr waitpoint respond wp_c91d --value '{\"approved\":true}'");
      await sleep(reduceMotion ? 0 : 500);

      const psLine = appendLine('<span class="t-prompt">$</span> <span class="t-cmd"></span>', "t-line t-gap");
      const psCommand = psLine?.querySelector(".t-cmd");
      if (psCommand) await typeInto(psCommand, "helmr ps");
      await sleep(reduceMotion ? 0 : 350);
      appendLine("RUN ID    TASK       STATUS     WAIT", "t-line t-dim");
      appendLine('run_8f3a  review-pr  <span class="t-ok">succeeded</span>', "t-line");
      await sleep(reduceMotion ? 0 : 250);
      appendLine('<span class="t-prompt">$</span> <span class="t-cursor"></span>', "t-line t-gap");
      void maybeSweep();
    });

    const startDemo = async () => {
      if (!term || !termFoot) return;
      if (!reduceMotion) await replayBoot();
      landing?.setAttribute("data-circuit-ready", "");
      termFoot.setAttribute("data-ready", "");
      runStarted = true;
      void maybeSweep();
      // Preview hook for screenshot verification.
      if (new URLSearchParams(window.location.search).has("autoapprove")) {
        approveButton?.click();
      }
    };
    startDemo();
  </script>
</BaseLayout>

<style>
  .landing {
    position: relative;
    overflow-x: clip;
  }

  /* CSS anchor positioning ties the waitpoint wire to the terminal and code row. */
  .circuit { display: none; }

  @supports (anchor-name: --wp) {
    .term { anchor-name: --term; }
    .term-body :global(.t-accent) { anchor-name: --wp-token; }
    .code-frame { anchor-name: --code-frame; }
    .cl-mark + :global(.cl) { anchor-name: --wp-line; }

    .circuit {
      display: block;
      opacity: 0;
      transition: opacity 0.5s ease-out;
    }

    .landing[data-circuit-ready] .circuit { opacity: 1; }
    .landing[data-wp-resolved] .circuit { opacity: 0; }

    .circuit-edge-out {
      position: absolute;
      height: 0;
      top: calc(anchor(--wp-token center) - 0.5px);
      left: calc(anchor(--term right) + 7px);
      right: calc(anchor(--code-frame right) - 32px);
      border-top: 1px dashed var(--accent-border);
    }

    .circuit-edge-rail {
      position: absolute;
      width: 0;
      top: calc(anchor(--wp-token center) - 0.5px);
      bottom: calc(anchor(--wp-line center) - 0.5px);
      right: calc(anchor(--code-frame right) - 32px);
      border-left: 1px dashed var(--accent-border);
    }

    .circuit-edge-in {
      position: absolute;
      height: 0;
      top: calc(anchor(--wp-line center) - 0.5px);
      left: calc(anchor(--code-frame right) + 7px);
      right: calc(anchor(--code-frame right) - 32px);
      border-top: 1px dashed var(--accent-border);
    }

    .circuit-node {
      position: absolute;
      width: 5px;
      height: 5px;
      background: var(--accent);
    }

    .circuit-node-a {
      top: calc(anchor(--wp-token center) - 2px);
      left: calc(anchor(--term right) + 3px);
    }

    .circuit-node-b {
      top: calc(anchor(--wp-line center) - 2px);
      left: calc(anchor(--code-frame right) + 3px);
    }
  }

  @media (max-width: 1199px) {
    .circuit { display: none !important; }
  }

  section {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .hero {
    position: relative;
    max-width: none;
    padding: 0;
  }

  .hero-inner {
    display: grid;
    grid-template-columns: minmax(0, 1.18fr) minmax(0, 0.82fr);
    align-items: center;
    gap: 3rem;
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 4.25rem 1.5rem 4.75rem;
  }

  .hero-title {
    font-size: clamp(2.25rem, 4.5vw, 3.25rem);
    line-height: 1.1;
    max-width: 20ch;
  }

  .hero-lede {
    margin-top: 1.1rem;
    max-width: 33rem;
    color: var(--text-muted);
    font-size: 1rem;
    line-height: 1.6;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1.5rem;
  }

  .install-command {
    appearance: none;
    display: flex;
    align-items: center;
    gap: 0.68rem;
    width: min(100%, 26rem);
    margin-top: 1.1rem;
    border: 1.5px dashed var(--border-strong);
    border-radius: var(--radius-btn);
    background: transparent;
    color: var(--text-subtle);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    line-height: 1.35;
    padding: 0.5rem 0.7rem;
    cursor: pointer;
    text-align: left;
    transition: border-color 0.1s ease-out, color 0.1s ease-out, background 0.1s ease-out;
  }

  .install-command code {
    flex: 1 1 auto;
    min-width: 0;
    font: inherit;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .install-command:hover,
  .install-command:focus-visible {
    border-color: var(--accent);
    color: var(--text);
    background: var(--surface-raised);
    outline: 0;
  }

  .install-command:hover .copy-control,
  .install-command:focus-visible .copy-control {
    color: var(--accent);
  }

  .copy-control {
    display: flex;
    align-items: center;
    flex: 0 0 auto;
    justify-content: center;
    color: var(--text-subtle);
    transition: color 0.1s ease-out;
  }

  .copy-icon,
  .check-icon {
    width: 0.95rem;
    height: 0.95rem;
    flex: 0 0 auto;
    stroke: currentColor;
  }

  .check-icon { display: none; }
  .install-command[data-copied="true"] .copy-control { color: var(--ok); }
  .install-command[data-copied="true"] .copy-icon { display: none; }
  .install-command[data-copied="true"] .check-icon { display: block; }

  .term-body {

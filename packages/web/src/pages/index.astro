    max-width: 34rem;
    color: var(--text);
    font-family: var(--font-sans);
    font-size: clamp(1.25rem, 2.5vw, 1.85rem);
    font-weight: 500;
    letter-spacing: -0.06em;
    line-height: 1;
  }

  .closing-block a {
    flex: 0 0 auto;
    font-family: var(--font-mono);
    font-size: 0.75rem;
  }

  @media (max-width: 760px) {
    :global(.site-header) {
      height: auto;
    }

    :global(.site-nav) {
      width: calc(100% - 3rem);
      min-height: 2.25rem;
      padding: 0;
    }

    :global(.brand) {
      padding-left: 1.25rem;
    }

    :global(.nav-links) {
      display: none;
    }

    .minimal-hero {
      padding: 2.4rem 1.25rem 1.8rem;
    }

    .spec-grid,
    .code-section,
    .ledger-row,
    .closing-block {
      grid-template-columns: 1fr;
    }

    .spec-grid div,
    .spec-grid div:nth-child(even) {
      border-right: 0;
      border-bottom: 1px solid var(--border);
      padding: 1.3rem 1.25rem;
    }

    .spec-grid div:nth-last-child(-n + 2) {
      border-bottom: 1px solid var(--border);
    }

    .spec-grid div:last-child {
      border-bottom: 0;
    }

    .code-section {
      gap: 0;
    }

    .section-copy {
      padding: 2rem 1.25rem;
      border-right: 0;
      border-bottom: 1px solid var(--border);
    }

    .code-section pre {
      padding: 1.2rem 1rem 1.5rem;
      font-size: 0.68rem;
      line-height: 1.58;
    }

    .code-panel-title {
      padding: 0 1rem;
    }

    .runtime-ledger,
    .ledger-row span {
      border-right: 0;
    }

    .ledger-row span {
      padding: 0.95rem 1.25rem 0.2rem;
    }

    .ledger-row p {
      padding: 0 1.25rem 1rem;
    }

    .closing-block {
      display: grid;
      align-items: start;
      padding: 2.4rem 1.25rem 3rem;

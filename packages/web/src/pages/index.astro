    align-items: center;
    height: 100%;
    padding: 0 0.72rem;
    border-left: 1px solid rgba(15, 23, 42, 0.14);
    border-radius: 0;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0;
  }

  :global(.nav-links a:hover) {
    background: rgba(255, 255, 255, 0.72);
  }

  :global(.nav-actions) {
    display: none;
  }

  :global(.site-footer) {
    display: none;
  }

  .minimal-page {
    position: relative;
    max-width: 900px;
    margin: 0 auto;
    padding: 0 1.5rem;
    color: var(--text);
    font-family: var(--font-mono);
    font-size: 0.875rem;
  }

  .minimal-page::before {
    content: "";
    position: fixed;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    background:
      repeating-linear-gradient(0deg, rgba(15, 23, 42, 0.02) 0 1px, transparent 1px 4px),
      radial-gradient(circle, rgba(15, 23, 42, 0.045) 0.7px, transparent 0.85px);
    background-size: auto, 12px 12px;
    opacity: 0.68;
  }

  .minimal-window {
    position: relative;
    margin-top: 0;
    margin-bottom: 4.5rem;
    border: 1px solid rgba(15, 23, 42, 0.2);
    border-top: 0;
    background:
      repeating-linear-gradient(
        0deg,
        transparent 0,
        transparent 1.5px,
        rgba(255, 255, 255, 0.36) 1.5px,
        rgba(255, 255, 255, 0.36) 4px
      ),
      rgba(247, 248, 249, 0.94);
  }

  .minimal-hero {
    padding: 2.85rem 1.75rem 2.15rem;
    border-bottom: 1px solid var(--border-strong);
  }

  .eyebrow,
  .spec-grid span,
  .ledger-row span {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    letter-spacing: 0.055em;
    text-transform: uppercase;
    color: var(--text-subtle);
  }

  .minimal-hero h1 {
    max-width: 19ch;
    margin-top: 1.55rem;
    color: var(--text);
    font-family: var(--font-sans);
    font-size: clamp(2rem, 4.2vw, 3.35rem);
    font-weight: 500;
    letter-spacing: -0.06em;
    line-height: 1.04;
    text-wrap: balance;
  }

  .lede {
    max-width: 39rem;
    margin-top: 1rem;
    color: var(--text-muted);
    font-size: 0.86rem;
    letter-spacing: -0.01em;
    line-height: 1.65;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0;
    margin-top: 0.8rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
  }

  .hero-actions a,
  .closing-block a {
    border: 1px solid var(--border-strong);
    background: linear-gradient(to bottom, #fbfcfd 0%, #eef1f3 100%);
    color: var(--text);
    padding: 0.42rem 0.68rem;
    text-decoration: none;
  }

  .hero-actions a + a {
    border-left: 0;
  }

  .hero-actions a:hover,
  .closing-block a:hover {
    background: var(--text);
    color: var(--bg);
  }

  .install-command {
    appearance: none;
    display: flex;
    align-items: center;
    gap: 0.68rem;
    width: min(100%, 31rem);
    margin-top: 0.8rem;
    border: 1px solid var(--border-strong);
    border-radius: 0;
    background:
      repeating-linear-gradient(
        0deg,
        transparent 0,
        transparent 1.5px,
        rgba(255, 255, 255, 0.48) 1.5px,
        rgba(255, 255, 255, 0.48) 4px
      ),
      rgba(255, 255, 255, 0.46);
    color: rgba(17, 24, 39, 0.78);
    font-family: "Monaco", "SFMono-Regular", "Menlo", "Consolas", var(--font-mono);
    font-size: 0.75rem;
    line-height: 1.35;
    padding: 0.42rem 0.68rem;
    cursor: pointer;
    text-align: left;
    transition: border-color 0.08s ease, color 0.08s ease, background 0.08s ease;
  }

  .install-command code {
    flex: 1 1 auto;
    min-width: 0;
    font: inherit;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .install-command:hover,
  .install-command:focus-visible {
    border-color: rgba(15, 23, 42, 0.36);
    background:
      repeating-linear-gradient(
        0deg,
        transparent 0,
        transparent 1.5px,
        rgba(255, 255, 255, 0.58) 1.5px,
        rgba(255, 255, 255, 0.58) 4px
      ),
      rgba(255, 255, 255, 0.64);
    color: var(--text);
    outline: 0;
  }

  .copy-control {
    display: flex;
    align-items: center;
    flex: 0 0 auto;
    justify-content: center;
    color: rgba(17, 24, 39, 0.5);
    transition: color 0.08s ease;
  }

  .install-command:hover .copy-control,
  .install-command:focus-visible .copy-control {
    color: rgba(17, 24, 39, 0.78);
  }

  .copy-icon {
    width: 0.95rem;
    height: 0.95rem;
    flex: 0 0 auto;
    stroke: currentColor;
  }

  .install-command[data-copied="true"] .copy-control {
    color: #03b000;
  }

  .check-icon {
    display: none;
    width: 0.95rem;
    height: 0.95rem;
    flex: 0 0 auto;
    stroke: currentColor;
  }

  .install-command[data-copied="true"] .copy-icon {
    display: none;
  }

  .install-command[data-copied="true"] .check-icon {
    display: block;
  }

  .statement-block {
    padding: 2.45rem 1.75rem 2.35rem;
    border-bottom: 1px solid var(--border-strong);
  }

  .statement-block p {
    max-width: 43rem;
    color: var(--text);
    font-family: var(--font-sans);
    font-size: clamp(1.05rem, 2.1vw, 1.55rem);
    font-weight: 500;
    letter-spacing: -0.05em;
    line-height: 1.12;
  }

  .spec-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    border-bottom: 1px solid var(--border-strong);
  }

  .spec-grid div {
    min-height: 9.5rem;
    border-right: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    padding: 1.1rem 1.25rem 1.25rem 1.75rem;
  }

  .spec-grid div:nth-child(even) {
    border-right: 0;
    padding-left: 1.25rem;
    padding-right: 1.75rem;
  }

  .spec-grid div:nth-last-child(-n + 2) {
    border-bottom: 0;
  }

  .spec-grid h2 {
    max-width: 13rem;
    margin-top: 1.4rem;
    color: var(--text);
    font-family: var(--font-sans);
    font-size: 0.98rem;
    font-weight: 500;
    letter-spacing: -0.045em;
    line-height: 1.08;
  }

  .spec-grid p {
    max-width: 22rem;
    margin-top: 0.55rem;
    color: rgba(17, 24, 39, 0.58);
    font-size: 0.74rem;
    line-height: 1.6;
  }

  .code-section {
    display: grid;
    grid-template-columns: minmax(0, 0.31fr) minmax(0, 0.69fr);
    gap: 0;
    padding: 0;
    border-bottom: 1px solid var(--border-strong);
  }

  .section-copy {
    padding: 2.2rem 1.75rem;
    border-right: 1px solid var(--border);
  }

  .section-copy h2 {
    max-width: 13rem;
    margin-top: 0.85rem;
    color: var(--text);
    font-family: var(--font-sans);
    font-size: clamp(1.15rem, 2.15vw, 1.55rem);
    font-weight: 500;
    letter-spacing: -0.055em;
    line-height: 1.05;
  }

  .section-note {
    max-width: 14.5rem;
    margin-top: 1rem;
    color: rgba(17, 24, 39, 0.58);
    font-size: 0.72rem;
    line-height: 1.55;
  }

  .code-panel {
    min-width: 0;
    background:
      repeating-linear-gradient(
        0deg,
        transparent 0,
        transparent 1.5px,
        rgba(255, 255, 255, 0.48) 1.5px,
        rgba(255, 255, 255, 0.48) 4px
      ),
      rgba(255, 255, 255, 0.38);
  }

  .code-panel-title {
    display: flex;
    align-items: center;
    justify-content: space-between;
    min-height: 1.95rem;
    border-bottom: 1px solid var(--border);
    background: rgba(255, 255, 255, 0.34);
    padding: 0 1.15rem;
    color: var(--text-subtle);
    font-family: "Monaco", "SFMono-Regular", "Menlo", var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0;
  }

  .code-panel-title span:first-child {
    color: rgba(17, 24, 39, 0.68);
  }

  .code-section pre {
    min-width: 0;
    margin: 0;
    overflow-x: hidden;
    padding: 1.35rem 1.25rem 1.55rem;
    color: #202833;
    font-family: "Monaco", "SFMono-Regular", "Menlo", "Consolas", var(--font-mono);
    font-size: 0.715rem;
    font-variant-ligatures: none;
    letter-spacing: -0.01em;
    line-height: 1.58;
    white-space: pre-wrap;
    overflow-wrap: anywhere;
    tab-size: 2;
  }

  .code-section code {
    font-family: inherit;
    font-size: inherit;
  }

  :global(.code-section .tok-keyword) {
    color: #395f8f;
    font-weight: 500;
  }

  :global(.code-section .tok-string) {
    color: #55715d;
  }

  :global(.code-section .tok-number) {
    color: #6a5d8f;
  }

  :global(.code-section .tok-call) {
    color: #28384f;
    font-weight: 500;
  }

  :global(.code-section .tok-property) {
    color: #5c6470;
  }

  :global(.code-section .tok-punct) {
    color: rgba(17, 24, 39, 0.54);
  }

  :global(.code-section .tok-comment) {
    color: rgba(17, 24, 39, 0.38);
    font-style: italic;
  }

  .runtime-ledger {
    border-bottom: 1px solid var(--border-strong);
  }

  .ledger-row {
    display: grid;
    grid-template-columns: 10rem 1fr;
    gap: 0;
    border-bottom: 1px solid var(--border);
  }

  .ledger-row:last-child {
    border-bottom: 0;
  }

  .ledger-row p {
    max-width: 44rem;
    padding: 0.82rem 1.75rem;
    color: var(--text);
    font-family: var(--font-sans);
    font-size: clamp(0.88rem, 1.3vw, 1rem);

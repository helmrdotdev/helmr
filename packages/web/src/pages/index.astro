    height: 2.25rem;
    border-bottom: 1px solid rgba(15, 23, 42, 0.2);
    background:
      repeating-linear-gradient(
        0deg,
        transparent 0,
        transparent 1.5px,
        rgba(255, 255, 255, 0.48) 1.5px,
        rgba(255, 255, 255, 0.48) 4px
      ),
      linear-gradient(to bottom, #fafafa 0%, #eceff2 100%);
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
  }

  :global(.site-nav) {
    max-width: calc(900px - 3rem);
    padding: 0;
    font-family: var(--font-mono);
    border-left: 1px solid rgba(15, 23, 42, 0.14);
    border-right: 1px solid rgba(15, 23, 42, 0.14);
  }

  :global(.brand) {
    gap: 0.45rem;
    align-self: stretch;
    padding-left: 1.75rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 400;
    letter-spacing: 0;
  }

  :global(.brand-icon) {
    width: 16px;
    height: 16px;
    background: transparent;
    border-radius: 2px;
    border: 1px solid rgba(15, 23, 42, 0.24);
  }

  :global(.brand-icon svg) {
    width: 10px;
    height: 10px;
  }

  :global(.brand-icon path) {
    fill: var(--text);
  }

  :global(.nav-links) {
    height: 100%;
  }

  :global(.nav-links a) {

---
import BaseLayout from "../layouts/BaseLayout.astro";
import { breadcrumbJsonLd, softwareJsonLd } from "../lib/seo";

const runtimeCode = `import { cache, image, sandbox, source, task } from "@helmr/sdk"
import { Codex } from "@openai/codex-sdk"

const base = image("repo-agent")
  .from("node:24-bookworm-slim")
  .workdir("/workspace")
  .run(["npm", "install", "-g", "bun@1.3.10"])
  .copy("/workspace/package.json", source.file("package.json"))
  .run(["bun", "install"], {
    cache: [{ mountPath: "/root/.bun/install/cache", cache: cache("repo-agent-bun") }]
  })
  .run([
    "sh",
    "-ceu",
    "apt-get update && apt-get install -y git ripgrep"
  ])

const sbx = sandbox("repo-agent")
  .image(base)
  .resources({ cpu: 2, memory: "4Gi" })

export const reviewPr = task({
  id: "review-pr",
  sandbox: sbx,
  maxDuration: 900,
  secrets: {
    OPENAI_API_KEY: { env: "OPENAI_API_KEY" }
  },
  run: async (event, ctx) => {
    const codex = new Codex({
      env: { CODEX_API_KEY: process.env.OPENAI_API_KEY ?? "" }
    })
    const thread = codex.startThread({ workingDirectory: process.cwd() })
    const turn = await thread.run("Review this PR and propose a patch.")
    const summary = turn.finalResponse

    const decision = await ctx.wait.token<{ approved: boolean }>({
      displayText: "Post this review to GitHub?"
    })
    if (decision.approved) await postReview(event.prNumber, summary)
  }
})`;

const escapeHtml = (value: string) =>
  value
    .replaceAll("&", "&amp;")
    .replaceAll("<", "&lt;")
    .replaceAll(">", "&gt;");

const syntaxKeywords = ["import", "from", "export", "const", "new", "async", "await", "if", "as"] as const;
const syntaxLiterals = ["true", "false", "null", "undefined"] as const;
const syntaxReserved = new Set<string>([...syntaxKeywords, ...syntaxLiterals]);
const syntaxReservedPattern = [...syntaxKeywords, ...syntaxLiterals].join("|");

const highlightTypeScript = (value: string) => {
  const tokenPattern = new RegExp(
    `("(?:\\\\.|[^"\\\\])*"|'(?:\\\\.|[^'\\\\])*'|\\/\\/.*|\\b(?:${syntaxReservedPattern})\\b|\\b\\d+\\b|\\.[A-Za-z_$][\\w$]*|\\b[A-Za-z_$][\\w$]*(?=\\()|[{}()[\\].,:])`,
    "g",
  );
  let cursor = 0;
  let html = "";

  for (const match of value.matchAll(tokenPattern)) {
    const token = match[0];
    const index = match.index ?? 0;
    html += escapeHtml(value.slice(cursor, index));

    let tokenClass = "tok-punct";
    if (token.startsWith('"') || token.startsWith("'")) tokenClass = "tok-string";
    else if (token.startsWith("//")) tokenClass = "tok-comment";
    else if (/^\d+$/.test(token)) tokenClass = "tok-number";
    else if (token.startsWith(".")) tokenClass = "tok-property";
    else if (syntaxReserved.has(token)) {
      tokenClass = "tok-keyword";
    } else if (/^[A-Za-z_$]/.test(token)) {
      tokenClass = "tok-call";
    }

    html += `<span class="${tokenClass}">${escapeHtml(token)}</span>`;
    cursor = index + token.length;
  }

  return html + escapeHtml(value.slice(cursor));
};

const highlightedRuntimeCode = highlightTypeScript(runtimeCode);
---

<BaseLayout
  title="Helmr - Self-hosted execution layer for coding agents"
  description="Helmr runs coding-agent work against your GitHub repositories on self-hosted infrastructure, with Firecracker isolation, scoped secrets, logs, and approval gates before write-back."
  path="/"
  jsonLd={[softwareJsonLd(), breadcrumbJsonLd([{ name: "Home", path: "/" }])]}
>
  <div class="minimal-page">
    <div class="minimal-window">
      <section class="minimal-hero">
        <p class="eyebrow">Helmr / self-hosted execution layer for coding agents</p>
        <h1>Run coding-agent workflows on your infrastructure.</h1>
        <p class="lede">
          Bring any agent SDK to private GitHub checkouts, Firecracker
          microVMs, task-scoped secrets, logs, and approval gates before
          write-back.
        </p>
        <button class="install-command" type="button" data-copy-install aria-label="Copy install command">
          <code data-install-command>curl -fsSL https://helmr.dev/install | bash</code>
          <span class="copy-control" aria-hidden="true">
            <svg class="copy-icon" viewBox="0 0 24 24" fill="none">
              <path d="M8.75 8.75V2.75H21.25V15.25H15.25M15.25 8.75H2.75V21.25H15.25V8.75Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="square" />
            </svg>
            <svg class="check-icon" viewBox="0 0 24 24" fill="none">
              <path d="M2.75 15.0938L9 20.25L21.25 3.75" stroke="currentColor" stroke-width="2" stroke-linecap="square" />
            </svg>
          </span>
        </button>
        <div class="hero-actions" aria-label="Primary actions">
          <a href="/docs">Read docs</a>
          <a href="https://github.com/helmrdotdev/helmr" target="_blank" rel="noopener">GitHub</a>
        </div>
      </section>

      <section class="statement-block" aria-label="Product position">
        <p>
          Models can plan. Agent SDKs can call tools. Sandbox services can
          execute commands. Production coding-agent workflows still need an
          execution layer for repo access, isolation, credentials, logs, and hard stops
          before side effects.
        </p>
      </section>

      <section id="platform" class="spec-grid" aria-label="Runtime primitives">
        <div>
          <span>01</span>
          <h2>Define tasks in TypeScript.</h2>
          <p>Declare the image, sandbox, resources, secrets, inputs, and run logic.</p>
        </div>
        <div>
          <span>02</span>
          <h2>Run on GitHub checkouts.</h2>
          <p>Start from a product, CLI, CI job, or webhook with a repo, ref, and path.</p>
        </div>
        <div>
          <span>03</span>
          <h2>Stop at waitpoints.</h2>
          <p>Let agents prepare reviews, patches, or actions, then require approval before write-back.</p>
        </div>
        <div>
          <span>04</span>
          <h2>Own the execution boundary.</h2>
          <p>Run API, dispatch, and workers in your AWS account, behind your GitHub App.</p>
        </div>
      </section>

      <section class="code-section" aria-label="TypeScript runtime definition">
        <div class="section-copy">
          <p class="eyebrow">Runtime definition</p>
          <h2>A task binds a sandbox, secrets, TypeScript run logic, and human approval points.</h2>
          <p class="section-note">Use Codex here, or replace it with any coding-agent SDK. The runtime boundary stays the same.</p>
        </div>
        <div class="code-panel">
          <div class="code-panel-title">
            <span>review-pr.ts</span>
            <span>TypeScript</span>
          </div>
          <pre><code set:html={highlightedRuntimeCode}></code></pre>
        </div>
      </section>

      <section class="runtime-ledger" aria-label="What Helmr provides">
        <div class="ledger-row">
          <span>workspace</span>
          <p>A GitHub checkout mounted inside the guest.</p>
        </div>
        <div class="ledger-row">
          <span>isolation</span>
          <p>Task code runs inside Firecracker microVMs.</p>
        </div>
        <div class="ledger-row">
          <span>control</span>
          <p>Approvals, denials, run status, logs, and history.</p>
        </div>
        <div class="ledger-row">
          <span>secrets</span>
          <p>Task-declared secrets injected only at run time.</p>
        </div>
        <div class="ledger-row">
          <span>ownership</span>
          <p>Your AWS account, your GitHub App, your runtime boundary.</p>
        </div>
      </section>

      <section class="closing-block">
        <p>Bring the model. Run the agents. Keep the runtime in your account.</p>
        <a href="/docs">Start with the docs</a>
      </section>
    </div>
  </div>

  <script>
    const copyInstallButton = document.querySelector("[data-copy-install]");
    const installCommand = document.querySelector("[data-install-command]");

    copyInstallButton?.addEventListener("click", async () => {
      const text = installCommand?.textContent?.trim();
      if (!text) return;
      try {
        await navigator.clipboard.writeText(text);
      } catch {
        return;
      }
      copyInstallButton.setAttribute("data-copied", "true");
      window.setTimeout(() => {
        copyInstallButton.removeAttribute("data-copied");
      }, 1600);
    });
  </script>
</BaseLayout>

<style>

---
import BaseLayout from "./BaseLayout.astro";
import { getAdjacentDocs, getDocLabel, getDocUrl, groupDocs, type DocEntry } from "../lib/docs";
import { breadcrumbJsonLd, docArticleJsonLd, docsCollectionJsonLd, type JsonLdNode } from "../lib/seo";

type Heading = {
  depth: number;
  slug: string;
  text: string;
};

type Props = {
  title: string;
  description: string;
  docs: DocEntry[];
  currentDoc?: DocEntry;
  headings?: Heading[];
};

const { title, description, docs, currentDoc, headings = [] } = Astro.props;
const groups = groupDocs(docs);
const adjacent = currentDoc ? getAdjacentDocs(docs, currentDoc.id) : undefined;
const pageTitle = currentDoc ? `${currentDoc.data.title} | Helmr Docs` : title;
const pagePath = currentDoc ? getDocUrl(currentDoc) : "/docs";
const toc = headings.filter((heading) => heading.depth === 2 || heading.depth === 3);
const docsJsonLd: JsonLdNode[] = currentDoc
  ? [
      docArticleJsonLd(currentDoc, pagePath),
      breadcrumbJsonLd([
        { name: "Docs", path: "/docs" },
        { name: currentDoc.data.title, path: pagePath },
      ]),
    ]
  : [
      docsCollectionJsonLd(),
      breadcrumbJsonLd([
        { name: "Home", path: "/" },
        { name: "Docs", path: "/docs" },
      ]),
    ];
---

<BaseLayout
  title={pageTitle}
  description={description}
  path={pagePath}
  type={currentDoc ? "article" : "website"}
  jsonLd={docsJsonLd}
  enableClientRouter
>
  <button slot="header-start" class="menu-button" type="button" data-docs-menu aria-label="Open docs navigation">
    <span></span>
    <span></span>
    <span></span>
  </button>

  <div class="docs-page">
    <div class="docs-toolbar">
      <div class="crumbs" aria-label="Breadcrumb">
        <a href="/docs" data-astro-prefetch="viewport">Docs</a>
        {currentDoc && <span>/</span>}
        {currentDoc && <span>{getDocLabel(currentDoc)}</span>}
      </div>
      <label class="docs-search">
        <span>Search</span>
        <input type="search" placeholder="Filter docs" data-docs-search />
      </label>
    </div>

    <section class="docs-frame" aria-label="Documentation">
      <div class="docs-shell">
        <aside class="docs-sidebar" id="docs-sidebar" aria-label="Docs navigation">
          {
            groups.map((group) => (
              <div class="docs-nav-group">
                <p>{group.section}</p>
                {group.docs.map((doc) => {
                  const isActive = currentDoc?.id === doc.id;
                  const prefetchStrategy = currentDoc?.data.section === group.section ? "viewport" : "hover";
                  return (
                    <a
                      href={getDocUrl(doc)}
                      class:list={{ active: isActive }}
                      aria-current={isActive ? "page" : undefined}
                      data-astro-prefetch={prefetchStrategy}
                      data-docs-item
                    >
                      <span>{String(doc.data.order).padStart(2, "0")}</span>
                      {getDocLabel(doc)}
                    </a>
                  );
                })}
              </div>
            ))
          }
        </aside>

        <main class="docs-main">
          <article class="docs-content">
            <slot />
          </article>

          {
            adjacent && (
              <nav class="doc-pagination" aria-label="Docs pagination">
                {adjacent.previous ? (
                  <a href={getDocUrl(adjacent.previous)} data-astro-prefetch="viewport">
                    <span>Previous</span>
                    {adjacent.previous.data.title}
                  </a>
                ) : (
                  <span></span>
                )}
                {adjacent.next ? (
                  <a href={getDocUrl(adjacent.next)} data-astro-prefetch="viewport">
                    <span>Next</span>
                    {adjacent.next.data.title}
                  </a>
                ) : (
                  <span></span>
                )}
              </nav>
            )
          }
        </main>

        <aside class="docs-toc" aria-label="On this page">
          <p>On this page</p>
          {
            toc.length > 0 ? (
              toc.map((heading) => (
                <a class={`depth-${heading.depth}`} href={`#${heading.slug}`}>
                  {heading.text}
                </a>
              ))
            ) : (
              <span>Overview</span>
            )
          }
        </aside>
      </div>
    </section>
  </div>

  <script>
    let docsController: AbortController | undefined;

    const initDocsControls = () => {
      docsController?.abort();
      docsController = new AbortController();
      const { signal } = docsController;

      const menuButton = document.querySelector("[data-docs-menu]");
      const sidebar = document.querySelector(".docs-sidebar");
      const search = document.querySelector("[data-docs-search]");
      const navItems = [...document.querySelectorAll("[data-docs-item]")];

      menuButton?.addEventListener(
        "click",
        () => {
          sidebar?.classList.toggle("open");
        },
        { signal },
      );

      document.addEventListener(
        "click",
        (event) => {
          const target = event.target;
          if (!(target instanceof Node) || !sidebar?.classList.contains("open")) return;
          if (sidebar.contains(target) || menuButton?.contains(target)) return;
          sidebar.classList.remove("open");
        },
        { signal },
      );

      search?.addEventListener(
        "input",
        (event) => {
          const target = event.target;
          if (!(target instanceof HTMLInputElement)) return;
          const query = target.value.trim().toLowerCase();

          for (const item of navItems) {
            const text = item.textContent?.toLowerCase() ?? "";
            item.toggleAttribute("hidden", query.length > 0 && !text.includes(query));
          }
        },
        { signal },
      );
    };

    document.addEventListener("astro:page-load", initDocsControls);
    initDocsControls();
  </script>
</BaseLayout>

<style>
  :global(.site-header) {
    height: 2.5rem;
    border-bottom: 1px solid var(--border);
    background: rgba(255, 255, 255, 0.92);
  }

  :global(.site-nav) {
    max-width: 1280px;
    padding: 0;
    border-left: 1px solid var(--border);
    border-right: 1px solid var(--border);
  }

  :global(.site-nav .brand) {
    align-self: stretch;
    padding: 0 1rem;
    font-size: 0.875rem;
  }

  :global(.site-nav .brand-mark) {
    width: 14px;
    height: 14px;
  }

  :global(.nav-links) {
    height: 100%;
    gap: 0;
  }

  :global(.nav-links a) {
    display: flex;
    align-items: center;
    height: 100%;
    padding: 0 0.85rem;
    border: 0;
    border-left: 1px solid var(--border);
    border-radius: 0;
    font-size: 0.72rem;
  }

  :global(.nav-links a:hover) {
    background: var(--accent-wash);
    border-color: var(--border);
    color: var(--accent);
  }

  :global(.nav-links a:hover .khint) {
    color: var(--accent);
  }

  :global(.nav-actions) {
    display: none;
  }

  :global(.site-footer) {
    display: none;
  }

  :global(::view-transition-group(*)),
  :global(::view-transition-old(*)),
  :global(::view-transition-new(*)),
  :global([data-astro-transition-scope]) {
    animation: none !important;
  }

  .docs-page {
    --docs-shell-inset: 1rem;
    --docs-nav-h: 2.5rem;
    --docs-bar-h: 2.5rem;
    --docs-top: calc(var(--docs-nav-h) + var(--docs-bar-h));
    min-height: calc(100vh - var(--docs-nav-h));
  }

  .docs-frame {
    max-width: 1280px;
    margin: 0 auto;
    border-left: 1px solid var(--border);
    border-right: 1px solid var(--border);
    background: var(--bg);
  }

  .docs-toolbar {
    position: sticky;
    top: var(--docs-nav-h);
    z-index: 80;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(14rem, 28rem);
    align-items: center;
    gap: 0.75rem;
    max-width: 1280px;
    min-height: var(--docs-bar-h);
    margin: 0 auto;
    padding: 0 var(--docs-shell-inset);
    border-right: 1px solid var(--border);
    border-left: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }

  .menu-button {
    display: none;
    place-items: center;
    grid-template-rows: repeat(3, 1px);
    align-content: center;
    row-gap: 0.22rem;
    width: 1.75rem;
    height: 1.75rem;
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-btn);
    background: var(--btn-surface);
    color: var(--text);
    padding: 0;
    appearance: none;
    -webkit-appearance: none;
  }

  .menu-button span {
    display: block;
    width: 0.86rem;
    height: 1px;
    background: currentColor;
  }

  .crumbs {
    display: flex;
    align-items: center;
    min-width: 0;
    gap: 0.4rem;
    color: var(--text-muted);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    white-space: nowrap;
  }

  .crumbs a {
    color: var(--text);
    text-decoration: none;
  }

  .crumbs a:hover {
    color: var(--accent);
  }

  .crumbs span:last-child {
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .docs-search {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    align-items: center;
    gap: 0.45rem;
    color: var(--text-subtle);
    font-family: var(--font-mono);
    font-size: 0.65rem;
    justify-self: stretch;
  }

  .docs-search input {
    min-width: 0;
    height: 1.65rem;
    border: 1px solid var(--border-strong);
    border-radius: 0;
    background: var(--bg);
    color: var(--text);
    font: inherit;
    padding: 0 0.5rem;
    outline: none;
  }

  .docs-search input:focus {
    border-color: var(--accent);
    box-shadow: 0 0 0 2px var(--accent-wash);
  }

  .docs-shell {
    display: grid;
    grid-template-columns: 15rem minmax(0, 1fr) 13rem;
    min-height: calc(100vh - var(--docs-top));
  }

  .docs-sidebar,
  .docs-toc {
    position: sticky;
    top: var(--docs-top);
    align-self: start;
    height: calc(100vh - var(--docs-top));
    overflow-y: auto;
  }

  .docs-sidebar {
    border-right: 1px solid var(--border);
    background: var(--surface-raised);
    padding: var(--docs-shell-inset);
  }

  .docs-nav-group + .docs-nav-group {
    margin-top: 1rem;
  }

  .docs-nav-group p,
  .docs-toc p {
    margin-bottom: 0.35rem;
    color: var(--text-subtle);
    font-family: var(--font-mono);
    font-size: 0.62rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .docs-nav-group a,
  .docs-toc a {
    display: block;
    color: var(--text-muted);
    font-size: 0.74rem;
    line-height: 1.35;
    text-decoration: none;
  }

  .docs-nav-group a {
    margin: 0.12rem 0;
    padding: 0.32rem 0.42rem;
  }

  .docs-nav-group a:hover,
  .docs-toc a:hover {
    background: var(--accent-wash);
    color: var(--accent);
  }

  .docs-nav-group a.active {
    background: var(--accent);
    color: var(--accent-fg);
  }

  .docs-nav-group a[hidden] {
    display: none;
  }

  .docs-nav-group a span {
    margin-right: 0.45rem;
    color: var(--text-subtle);
    font-family: var(--font-mono);
    font-size: 0.62rem;
  }

  .docs-nav-group a:hover span {
    color: var(--accent-faint);
  }

  .docs-nav-group a.active span {
    color: rgba(255, 255, 255, 0.66);
  }

  .docs-main {
    min-width: 0;
    background: var(--bg);
  }

  .docs-content {
    width: 100%;
    max-width: 48rem;
    padding: 2.25rem 2.5rem 2rem;
    color: var(--text);
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    font-weight: 450;
    line-height: 1.7;
    letter-spacing: 0.005em;
    text-rendering: optimizeLegibility;
  }

  .docs-toc {
    border-left: 1px solid var(--border);
    background: var(--surface-raised);
    padding: 1rem 0.75rem;
  }

  .docs-toc a,
  .docs-toc span {
    margin: 0.1rem 0;
    padding: 0.26rem 0.38rem;
    color: var(--text-muted);
    font-size: 0.68rem;
    line-height: 1.35;
  }

  .docs-toc .depth-3 {
    padding-left: 0.9rem;
  }

  .doc-pagination {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
    max-width: 43rem;
    margin: 0 2.5rem 2.5rem;
    border-top: 1px solid var(--border);
    padding-top: 1.25rem;
  }

  .doc-pagination a {
    display: block;
    min-height: 4rem;
    border: 1px solid var(--border);
    background: var(--surface-raised);
    color: var(--text);
    padding: 0.8rem 0.9rem;
    font-size: 0.8125rem;
    font-weight: 500;
    line-height: 1.35;
    text-decoration: none;
    transition: border-color 0.1s ease-out, background 0.1s ease-out, color 0.1s ease-out;
  }

  .doc-pagination a:hover {
    border-color: var(--accent);
    background: var(--accent-wash);
    color: var(--accent);
  }

  .doc-pagination a + a {
    text-align: right;
  }

  .doc-pagination span {
    display: block;
    margin-bottom: 0.28rem;
    color: var(--text-subtle);
    font-family: var(--font-mono);
    font-size: 0.62rem;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .doc-pagination a:hover span {
    color: var(--accent-faint);
  }

  :global(.docs-content h1) {
    margin: 0 0 1rem;
    border-bottom: 1px solid var(--border);
    padding-bottom: 0.85rem;
    color: var(--text);
    font-family: "Geist", var(--font-sans);
    font-size: 1.75rem;
    font-weight: 560;
    line-height: 1.1;
    letter-spacing: -0.016em;
  }

  :global(.docs-content h2) {
    margin: 2rem 0 0.7rem;
    color: var(--text);
    font-family: "Geist", var(--font-sans);
    font-size: 1.125rem;
    font-weight: 560;
    line-height: 1.2;
    letter-spacing: -0.012em;
  }

  :global(.docs-content h3) {
    margin: 1.35rem 0 0.45rem;
    color: var(--text);
    font-family: "Geist", var(--font-sans);
    font-size: 0.95rem;
    font-weight: 560;
    letter-spacing: -0.008em;
  }

  :global(.docs-content p) {
    max-width: 68ch;
  }

  :global(.docs-content p),
  :global(.docs-content ul),
  :global(.docs-content ol),
  :global(.docs-content table),
  :global(.docs-content blockquote) {
    margin: 0.85rem 0;
  }

  :global(.docs-content ul),
  :global(.docs-content ol) {
    padding-left: 1.35rem;
  }

  :global(.docs-content li) {
    margin: 0.25rem 0;
  }

  :global(.docs-content a) {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  :global(.docs-content code) {
    border: 0;
    border-radius: 0;
    background: rgba(27, 27, 166, 0.07);
    padding: 0.12rem 0.3rem;
    color: var(--text);
    font-family: var(--font-mono);
    font-size: 0.8em;
  }

  :global(.docs-content pre) {
    position: relative;
    max-width: 100%;
    overflow-x: auto;
    margin: 1.1rem 0;
    border: 1px solid var(--border-strong);
    background: var(--frame-bg) !important;
    color: var(--frame-text);
    padding: 2.2rem 1rem 0.85rem;
    line-height: 1.55;
  }

  :global(.docs-content pre code),
  :global(.docs-content pre span) {
    border: 0;
    background: transparent;
    padding: 0;
    font-size: 0.78rem;
  }

  :global(.docs-content pre[data-language]::before) {
    content: attr(data-language);
    position: absolute;
    top: 0;
    right: 0;
    left: 0;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    height: 1.55rem;
    border-bottom: 1px solid var(--frame-line);
    background: rgba(20, 20, 184, 0.04);
    padding: 0 0.75rem;
    color: var(--frame-subtle);
    font-family: var(--font-mono);
    font-size: 0.65rem;
    line-height: 1;
  }

  :global(.docs-content .line) {
    min-height: 1.2rem;
  }

  :global(.docs-content table) {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.78rem;
  }

  :global(.docs-content th),
  :global(.docs-content td) {
    border: 1px solid var(--border);
    padding: 0.48rem 0.6rem;
    text-align: left;
    vertical-align: top;
  }

  :global(.docs-content th) {
    background: var(--surface-raised);
  }

  :global(.docs-content blockquote) {
    border-left: 3px solid var(--accent);
    background: var(--accent-wash);
    padding: 0.6rem 0.8rem;
    color: var(--text-muted);
  }

  @media (max-width: 960px) {
    .docs-shell {
      grid-template-columns: 15rem minmax(0, 1fr);
    }

    .docs-toc {
      display: none;
    }
  }

  @media (max-width: 760px) {
    .docs-page {
      padding: 0;
    }

    .docs-frame {
      border: 0;
    }

    .docs-toolbar {
      grid-template-columns: minmax(0, 1fr);
      min-height: 2.4rem;
      padding: 0.45rem 1.15rem;
      border-right: 0;
      border-left: 0;
    }

    .menu-button {
      display: inline-grid;
      width: 2rem;
      height: 2rem;
      margin-left: 0.55rem;
      margin-right: 0.35rem;
      border: 0;
      background: transparent;
    }

    :global(.site-nav) {
      justify-content: flex-start;
      gap: 0;
    }

    :global(.site-nav .brand) {
      padding-left: 0;
      font-size: 0.8rem;
      gap: 0;
    }

    .crumbs {
      display: none;
    }

    .docs-search {
      grid-template-columns: 3rem minmax(0, 1fr);
    }

    .docs-shell {
      display: block;
      min-height: auto;
    }

    .docs-sidebar {
      position: fixed;
      top: var(--docs-nav-h);
      bottom: 0;
      left: -15.5rem;
      z-index: 200;
      width: 15rem;
      height: auto;
      border-right: 1px solid var(--border-strong);
      background: var(--surface-raised);
      transition: left 0.16s ease;
    }

    .docs-sidebar.open {
      left: 0;
    }

    .docs-content {
      max-width: none;
      padding: 1.5rem 1.15rem;
      font-size: 0.84rem;
    }

    .doc-pagination {
      grid-template-columns: 1fr;
      margin: 0 1.15rem 1.5rem;
    }

    .doc-pagination a + a {
      border-top: 0;
      border-left: 1px solid var(--border);
      text-align: left;
    }
  }
</style>

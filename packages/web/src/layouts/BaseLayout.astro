---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";
import {
  SITE,
  absoluteUrl,
  jsonLdGraph,
  organizationJsonLd,
  websiteJsonLd,
  type JsonLdNode,
} from "../lib/seo";

type Props = {
  title: string;
  socialTitle?: string;
  description?: string;
  path?: string;
  image?: string;
  type?: "website" | "article";
  noindex?: boolean;
  jsonLd?: JsonLdNode | JsonLdNode[];
  enableClientRouter?: boolean;
};

const {
  title,
  socialTitle = title,
  description = SITE.defaultDescription,
  path = Astro.url.pathname,
  image = SITE.defaultImage,
  type = "website",
  noindex = false,
  jsonLd = [],
  enableClientRouter = false,
} = Astro.props;

const canonicalUrl = absoluteUrl(path, Astro.site?.toString() ?? SITE.url);
const imageUrl = absoluteUrl(image, Astro.site?.toString() ?? SITE.url);
const imageAlt = "Helmr — the durable runtime for AI agents.";
const robots = noindex
  ? "noindex, nofollow"
  : "index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1";
const graphNodes = [
  organizationJsonLd(),
  websiteJsonLd(),
  ...(Array.isArray(jsonLd) ? jsonLd : [jsonLd]),
].filter(Boolean) as JsonLdNode[];
const serializeJsonLd = (data: JsonLdNode): string =>
  JSON.stringify(data)
    .replace(/</g, "\\u003c")
    .replace(/\u2028/g, "\\u2028")
    .replace(/\u2029/g, "\\u2029");
const structuredData = serializeJsonLd(jsonLdGraph(graphNodes));

const brandSpriteRows = [
  "................",
  "................",
  "................",
  ".......KK.......",
  ".....KKKKKK.....",
  "...KKKKKKKKKK...",
  ".....KKKKKK.....",
  ".......KK.......",
  "................",
  "...KK......KK...",
  ".....KK..KK.....",
  ".......KK.......",
  "................",
  "................",
  "................",
  "................",
] as const;
const brandSpriteColors: Record<string, string> = {
  K: "#1f1f24",
};
const brandSpritePixels = brandSpriteRows.flatMap((row, y) =>
  [...row].flatMap((ch, x) => (ch === "." ? [] : [{ x, y, fill: brandSpriteColors[ch] }])),
);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content={robots} />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#faf8f4" />
    <title>{title}</title>
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="sitemap" href="/sitemap.xml" />
    <link rel="alternate" type="text/plain" title="Helmr LLM guide" href="/llms.txt" />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:locale" content={SITE.locale} />
    <meta property="og:type" content={type} />
    <meta property="og:title" content={socialTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:image:alt" content={imageAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={socialTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    <meta name="twitter:image:alt" content={imageAlt} />
    <script is:inline type="application/ld+json" set:html={structuredData}></script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://api.fontshare.com" />
    <link rel="preconnect" href="https://cdn.fontshare.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DotGothic16&family=Geist+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://api.fontshare.com/v2/css?f[]=general-sans@400,500,600&display=swap"
      rel="stylesheet"
    />
    {enableClientRouter && <ClientRouter fallback="swap" />}
  </head>
  <body>
    <header class="site-header">
      <nav class="site-nav">
        <slot name="header-start" />
        <a class="brand" href="/">
          <svg class="brand-mark" viewBox="0 0 16 16" aria-hidden="true">
            {brandSpritePixels.map((pixel) => (
              <rect x={pixel.x} y={pixel.y} width="1" height="1" fill={pixel.fill} />
            ))}
          </svg>
          Helmr
        </a>
        <div class="nav-links">
          <a href="/docs/start/quickstart" data-astro-prefetch="viewport"><span class="khint">[q]</span>Quickstart</a>
          <a href="/docs" data-astro-prefetch="viewport"><span class="khint">[d]</span>Docs</a>
          <a href="https://github.com/helmrdotdev/helmr" target="_blank" rel="noopener"><span class="khint">[g]</span>GitHub</a>
        </div>
        <div class="nav-actions">
          <a class="btn btn-dark btn-sm" href="/docs/start/quickstart" data-astro-prefetch="viewport">Start building</a>
        </div>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <script is:inline>
      document.addEventListener("keydown", (event) => {
        if (event.metaKey || event.ctrlKey || event.altKey) return;
        const target = event.target;
        if (
          target instanceof HTMLElement &&
          (target.tagName === "INPUT" || target.tagName === "TEXTAREA" || target.isContentEditable)
        ) {
          return;
        }
        if (event.key === "q") window.location.href = "/docs/start/quickstart";
        if (event.key === "d") window.location.href = "/docs";
        if (event.key === "g") window.open("https://github.com/helmrdotdev/helmr", "_blank", "noopener");
      });
    </script>
    <footer class="site-footer">
      <div class="footer-inner">
        <h2 class="headline footer-headline">
          Bring your harness.<br />
          <span class="faint">We&rsquo;re the runtime.</span>
        </h2>
        <div class="footer-cta">
          <a class="btn btn-dark" href="/docs/start/quickstart" data-astro-prefetch="viewport">Start building</a>
        </div>
        <div class="footer-top">
          <div class="footer-brand">
            <a class="brand" href="/">
              <svg class="brand-mark" viewBox="0 0 16 16" aria-hidden="true">
                {brandSpritePixels.map((pixel) => (
                  <rect x={pixel.x} y={pixel.y} width="1" height="1" fill={pixel.fill} />
                ))}
              </svg>
              Helmr
            </a>
            <p class="footer-tagline">
              The durable runtime for AI agents.<br />
              Run it on our cloud or in your own AWS account.
            </p>
          </div>
          <div class="footer-links-group">
            <div class="footer-col">
              <h4>Product</h4>
              <a href="/#runtime">Runtime</a>
              <a href="/docs/start/quickstart" data-astro-prefetch="viewport">Quickstart</a>
              <a href="/docs" data-astro-prefetch="viewport">Documentation</a>
            </div>
            <div class="footer-col">
              <h4>Resources</h4>
              <a href="https://github.com/helmrdotdev/helmr" target="_blank" rel="noopener">GitHub</a>
              <a href="/docs/self-hosting/overview" data-astro-prefetch="viewport">Self-hosting</a>
              <a href="/docs/reference/sdk-authoring" data-astro-prefetch="viewport">SDK reference</a>
            </div>
          </div>
        </div>
        <div class="footer-bottom">
          <p class="footer-copy">© 2026 Helmr. Apache 2.0, built in the open.</p>
        </div>
      </div>
    </footer>
  </body>
</html>
